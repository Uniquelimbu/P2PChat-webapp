# Copy this file to .env and adjust values as needed.
# The dev script sets PORT and BASE_PATH automatically, so you normally do not need them here.

# Optional: override frontend API proxy target (defaults to http://localhost:8080)
# API_URL=http://localhost:8080

# Optional: explicit signaling URL if frontend and signaling are on different hosts.
# If empty, frontend uses same-host /ws.
# VITE_SIGNALING_WS_URL=wss://your-signaling-host/ws

# Optional: comma-separated STUN URLs (defaults are Google STUN servers).
# VITE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# Recommended for cross-WiFi reliability (different NAT types).
# VITE_TURN_URLS=turn:your-turn-host:3478?transport=udp,turn:your-turn-host:443?transport=tcp
# VITE_TURN_USERNAME=your-turn-username
# VITE_TURN_CREDENTIAL=your-turn-password

# Demo default: app includes a public TURN fallback when no custom TURN is set.
# Disable it if you want STUN-only behavior:
# VITE_DISABLE_PUBLIC_TURN=true

# Optional: force relay-only mode (uses TURN only).
# Set to relay when peers are on different networks and direct ICE fails.
# VITE_ICE_TRANSPORT_POLICY=relay

# Advanced: full ICE server JSON override (takes precedence over VITE_TURN_*).
# VITE_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:your-turn-host:3478"],"username":"u","credential":"p"}]
